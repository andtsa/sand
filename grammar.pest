// language definition
WHITESPACE = _{ " " | "\t" | "\n" | "\r" }
COMMENT    = _{ ("/*" ~ (!"*/" ~ ANY)* ~ "*/") | ("//" ~ (!"\n" ~ ANY)*) }

// primitive tokens

// Qualified type: `mod::TypeName`
qualified_type = { identifier ~ "::" ~ identifier }

// Ad-hoc tag union type: `#ok | #err` (structural, anonymous)
tag_type = { "#" ~ identifier ~ ("|" ~ "#" ~ identifier)* }

// Tuple type: `(Int, Bool)`, arity >= 2 (one element is just grouping, handled by build_type)
tuple_type = { "(" ~ type_ ~ ("," ~ type_)+ ~ ")" }

// Generic enum instantiation at a use site: `Option<Int>`, `Either<Int, Bool>`.
type_application = { identifier ~ "<" ~ type_ ~ ("," ~ type_)* ~ ">" }

// a lifetime / region: `'r`, `'heap`, `'static`. atomic so no internal
// whitespace is consumed between the tick and the name.
lifetime = @{ "'" ~ identifier }

core_type = {
    "Int"
  | "Bool"
  | "Unit" // equivalent to rust (), python None

  | qualified_type // cross-module enum type: mod::TypeName

  | tag_type // ad-hoc tag union: #ok | #err

  | tuple_type // product type: (A, B, ...)

  | type_application // generic instantiation: Option<Int>

  | borrow_type // shared reference: &T, &'r T

  | identifier // named enum type
}

// reference type `&'r T` (shared) or `&'r mut T` (exclusive) (Calculus §2.3).
// the lifetime is optional; an absent one is assigned a fresh region. the
// `mut` keyword marks an exclusive (mutable) borrow (Step 9).
borrow_type = { "&" ~ lifetime? ~ mut_kw? ~ core_type }

// a type, optionally ascribed to a region: `Int`, `Int @ 'r` (Calculus §2.3).
// the `@ 'r` suffix is parsed here (rather than a left-recursive `region_type`)
// so the grammar stays a valid PEG.
type_ = { core_type ~ ("@" ~ lifetime)? }

// keywords (prevent them from being identifiers)
KEYWORD = { "if" | "then" | "else" | "let" | "def" | "true" | "false" | "Unit" | "Int" | "Bool" | "while" | "do" | "module" | "mut" | "type" | "match" | "and" | "where" }

identifier       = @{ !(KEYWORD ~ !(ASCII_ALPHANUMERIC | "_")) ~ "_"* ~ ASCII_ALPHA ~ (ASCII_ALPHANUMERIC | "_")* }
empty_identifier = @{ "_" }

number = @{ ASCII_DIGIT+ }

boolean = @{ "true" | "false" }

unary_operand = { subtract | negate }

add      = { "+" }
subtract = { "-" }
multiply = { "*" }
divide   = { "/" }
pow      = { "^" }
negate   = { "!" }
// `&&` is bitwise AND (on Int); `and` is logical AND (on Bool). single `&` is
// reserved for borrow syntax (Step 7).
bitand   = { "&&" }
logand   = @{ "and" ~ !(ASCII_ALPHANUMERIC | "_") }
or       = { "|" }
xor      = { "⊕" | "¡" }
gt       = { ">" }
lt       = { "<" }
ne       = { "≠" | "!=" }
eq       = { "==" }
ge       = { ">=" | "≥" }
le       = { "<=" | "≤" }

// type parameters on a generic declaration: `<T>`, `<+a : Owned, -b>`.
// each parameter carries an optional variance annotation (`+`/`-`; absent =
// default) and an optional kind annotation (`: Owned`/`: Never`; absent =
// `Owned`). only appears in declaration position (right after the def/type
// name); uses of a type parameter inside a type are bare identifiers.
variance_ann = { "+" | "-" }
kind_ann     = { "Owned" | "Never" }
type_param   = { variance_ann? ~ identifier ~ (":" ~ kind_ann)? }
// a region (lifetime) parameter `'r` declared on a generic item (Calculus §8.4).
region_param = { lifetime }
type_params  = { "<" ~ (region_param | type_param) ~ ("," ~ (region_param | type_param))* ~ ">" }

// outlives constraints on a function signature: `where 'r >= 's` (Calculus
// §8.10). typeclass constraints (`where T : Clone`) arrive in Step 15.
where_constraint = { lifetime ~ ">=" ~ lifetime }
where_clause     = { "where" ~ where_constraint ~ ("," ~ where_constraint)* }

// enum type declarations
// a variant is a bare tag (`Red`, nullary) or a tag with a payload type (`Ok(Int)`)
enum_variant = { identifier ~ ("(" ~ type_ ~ ")")? }
type_alias   = { "type" ~ identifier ~ type_params? ~ "=" ~ enum_variant ~ ("|" ~ enum_variant)* ~ ";"? }

// enum constructors: Light#Red (local), mod::Light#Red (cross-module), or #Red (bare tag, needs check mode)
// an optional parenthesised argument supplies the variant's payload: `Result#Ok(5)`
external_constructor_expr = { identifier ~ "::" ~ identifier ~ "#" ~ identifier ~ ("(" ~ expression ~ ")")? }
constructor_expr          = { identifier ~ "#" ~ identifier ~ ("(" ~ expression ~ ")")? }
tag_expr                  = { "#" ~ identifier ~ ("(" ~ expression ~ ")")? }

// pattern matching
// patterns are recursive: a payload-carrying variant or a tuple may itself
// contain (irrefutable) sub-patterns that bind/destructure the payload.
wildcard_pattern    = { "_" }
binding_pattern     = { identifier }
tuple_pattern       = { "(" ~ pattern ~ ("," ~ pattern)+ ~ ")" }
tag_pattern         = { "#" ~ identifier ~ ("(" ~ pattern ~ ")")? }
constructor_pattern = { identifier ~ "#" ~ identifier ~ ("(" ~ pattern ~ ")")? }
// literal patterns (refutable; int/bool values in match position)
// bool_literal_pattern must precede binding_pattern so "true"/"false" are
// not captured as variable names (they are keywords, but the ordering makes
// the intent explicit). int_literal_pattern supports optional leading minus.
int_literal_pattern  = @{ "-"? ~ number }
bool_literal_pattern = @{ "true" | "false" }
pattern              =  { constructor_pattern | tag_pattern | tuple_pattern | wildcard_pattern | bool_literal_pattern | int_literal_pattern | binding_pattern }
match_arm            =  { pattern ~ "=>" ~ expression ~ ","? }
match_expr           =  { "match" ~ expression ~ "{" ~ match_arm+ ~ "}" }

// the language is built around expressions

ifstatement = {
    "if" ~ expression ~ "then" ~ expression ~ ("else" ~ expression)?
}

whileloop = {
    "while" ~ expression ~ "do" ~ expression
}

function_call          = { identifier ~ "(" ~ (expression ~ ("," ~ expression)*)? ~ ")" }
external_function_call = { identifier ~ "::" ~ identifier ~ "(" ~ (expression ~ ("," ~ expression)*)? ~ ")" }

// tuple literal: `(a, b, ...)`
tuple_expr = { "(" ~ expression ~ ("," ~ expression)+ ~ ")" }

// todo: anonymous functions (lambdas) & first class functions

// precedence chaining
// borrow expression `&e` (shared) or `&mut e` (exclusive) (Calculus §3.2 /
// §8.7). binds tightly (to a primary), so `&x + 1` is `(&x) + 1`.
borrow_expr = { "&" ~ mut_kw? ~ primary }
// dereference expression `*e`: read through a reference (`&T`/`&mut T` -> T).
// like `borrow_expr` it binds to a primary, so `*x + 1` is `(*x) + 1`. the
// prefix `*` is unambiguous with the infix multiply, which only appears
// between operands.
deref_expr = { "*" ~ primary }

primary = {
    borrow_expr
  | deref_expr
  | tuple_expr
  | ("(" ~ expression ~ ")")
  | ifstatement
  | whileloop
  | match_expr
  | function_call
  | external_function_call
  | external_constructor_expr
  | constructor_expr
  | tag_expr
  | number
  | boolean
  | identifier
  | ("{" ~ statement* ~ expression? ~ "}")
}

unary      = { (unary_operand ~ unary) | primary }
power      = { unary ~ (pow ~ power)? }
mul_div    = { power ~ ((multiply | divide) ~ power)* }
add_sub    = { mul_div ~ ((add | subtract) ~ mul_div)* }
comparison = { add_sub ~ ((ge | le | gt | lt) ~ add_sub)* }
equality   = { comparison ~ ((eq | ne) ~ comparison)* }
logic_and  = { equality ~ ((logand | bitand) ~ equality)* }
logic_xor  = { logic_and ~ (xor ~ logic_and)* }
logic_or   = { logic_xor ~ (or ~ logic_xor)* }
expression = { logic_or }

mut_kw = { "mut" }

// tuple-pattern `let` binding: `let (a, mut b) = expr`
let_tuple_elem = { mut_kw? ~ identifier }
let_tuple      = { "(" ~ let_tuple_elem ~ ("," ~ let_tuple_elem)+ ~ ")" }

// constructor-pattern `let` binding: `let E#V(payload) = expr else fallback`
// Sub-pattern elements are immutable bindings only (no mut_kw at this level), for now.
// Mutability in top-level let-tuple bindings (`let (a, mut b) = ...`) is unaffected.
let_binding_elem  = { identifier | empty_identifier }
let_binding_tuple = { "(" ~ let_binding_elem ~ ("," ~ let_binding_elem)+ ~ ")" }
let_destructure   = { let_constructor | let_binding_tuple | let_binding_elem }
let_constructor   = { identifier ~ "#" ~ identifier ~ ("(" ~ let_destructure ~ ")")? }

// borrow binding `let &x = e` (shared) or `let &mut x = e` (exclusive)
// (Calculus §3.2 / §6.4): `x` borrows `e`, so it stays usable and `e` is not
// consumed.
borrow_binding = { "&" ~ mut_kw? ~ (identifier | empty_identifier) }

// variables, either a single binding, a flat tuple-pattern, a constructor-pattern, or bare binding
// The `else` clause is required when the LHS is a refutable (constructor) pattern.
declaration = {
    "let" ~ (let_constructor | let_tuple | borrow_binding | mut_kw? ~ (identifier | empty_identifier)) ~ (":" ~ type_)? ~ "=" ~ expression ~ ("else" ~ expression)?
}

// `x = e` (reseat / variable write) or `*r = e` (write-through a `&mut`). The
// `=` disambiguates from a bare `*r` expression statement.
assignment = { (deref_expr | identifier) ~ "=" ~ expression }

// statements are the imperative elements of the language
statement = {
    ((declaration | assignment | expression) ~ ";")
}

// functions are highest-order tokens
parameter  = { mut_kw? ~ (identifier | empty_identifier) ~ ":" ~ type_ }
parameters = { parameter ~ ("," ~ parameter)* ~ ","? }

function = { "def" ~ identifier ~ type_params? ~ "(" ~ parameters? ~ ")" ~ ":" ~ type_ ~ where_clause? ~ ":=" ~ expression }

module = { "module" ~ identifier ~ ";"? }

program = { SOI ~ (function | type_alias | module)* ~ EOI }
