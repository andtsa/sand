def main(): Unit := {
    let a: Int = 5 + 9;
    let b: Int = 5 + 9;
    (5 + 9) * a / b;
    5 + 9; 
    5 + 9;
    1 + f(1, 5 + 9);
    f(5, 9) + 8;


    f(f(5, 9) + 9);
    let n: Unit = 4;
    n = f(n);
    n = f(n);
    f(n) + f(n);
    5 + 9
}

def f(x: Int, y: Int): Int := {
    if x > y then 2 else
    f(x - y, y - x) + f(y - x, x - y)
}
