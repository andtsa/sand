//@TEST:{3}[]
type Inner = X | Y
type Outer = A(Inner) | B

// This IS exhaustive: A(X) + A(Y) covers all of A, B covers B.
// Does the compiler accept it?
def f(o: Outer): Int :=
    match o {
        Outer#A(Inner#X) => 1,
        Outer#A(Inner#Y) => 2,
        Outer#B => 3,
    }

def main(): Int := f(Outer#B)
