// fibonacci

def fib(x: Int): Int := {
    1 + 2;
    if x ≤ 1 then 
        x 
    else 
        fib(x - 1) 
        + fib(x - 2)
}

def main(): Int := {
    let a: Int = 11;
    
    // we do not have lambdas, 
    // so there should be no collision 
    // between variable names and function names
    let fib: Int = fib(a);
    println(fib(a));
    
    0
}
