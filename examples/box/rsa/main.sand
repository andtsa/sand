// executable entry point 

def test(message: Int): Unit := {
    println(message);
    let cipher: Int = enc::rsa_encrypt(message);
    println(cipher);
    let plain: Int = dec::rsa_decrypt(cipher);
    println(plain);
}

def main(): Int := {
    let message: Int = 42;
    test(message);

    let msg: Int = 12345 + 1345765 + 343543;
    test(12345 + 1345765 + 343543);

    0
}

