//@TEST:{13}[]
// a generic enum is constructed, returned from a generic function, and consumed
// by `match` — all monomorphised before codegen.

type Option<T> = None | Some(T)

def wrap<T>(x: T): Option<T> := Option#Some(x)

def unwrap(o: Option<Int>): Int :=
    match o {
        Option#Some(x) => x,
        Option#None => 0,
    }

def main(): Int := unwrap(wrap(13))
