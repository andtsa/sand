//@TEST:{0}[61]

// Ackermann function is pure integer recursion used to stress-test deep recursion in the compiler.
// A(3, 3) = 61
//
//   A(0, n)    = n + 1
//   A(m, 0)    = A(m-1, 1)
//   A(m, n)    = A(m-1, A(m, n-1))

def ackermann(m: Int, n: Int): Int :=
    if m == 0 then n + 1
    else if n == 0 then ackermann(m - 1, 1)
    else ackermann(m - 1, ackermann(m, n - 1))

def main(): Int := {
    println(ackermann(3, 3));
    0
}
