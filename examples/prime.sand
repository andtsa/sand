def is_prime(n : Int): Bool := {
    let mut ok: Bool = true;
    if n ≤ 1 then false else {
        let mut i: Int = 2;

        while i^2 ≤ n do {
            if (n / i) * i == n then {
                ok = false;
                i = n; // break
            } else {
                i = i + 1;
            }
        };
        true
    };

    ok
}

def main(): Int := {
    let mut i: Int = 0;
    while i ≤ 100 do { if is_prime(i) then println(i); i = i + 1; };

    5
}
