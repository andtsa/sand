
type List<T> = Empty | Cons((T, List));

def push<T>(elem: T, list: &mut List<T>): Unit := {
    match list {
        List#Cons((x, List#Empty)) => {
            (*list) = List#Cons((x, List#Cons((elem, List#Empty))));
        }
        List#Cons((x, tail)) => push(elem, tail),
        List#Empty => {
            *list = List#Cons((elem, List#Empty));
        }
    };
}

def main(): Int := 0
