{
    "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
    "grammars": [
        {
            "name": "sand",
            "camelcase": "Sand",
            "title": "SAND",
            "scope": "source.sand",
            "file-types": [
                "sand"
            ],
            "injection-regex": "^sand$",
            "class-name": "TreeSitterSand"
        }
    ],
    "metadata": {
        "version": "0.0.1",
        "license": "MIT",
        "description": "diy language",
        "authors": [
            {
                "name": "sandess"
            }
        ],
        "links": {
            "repository": "https://github.com/andtsa/sand"
        }
    },
    "bindings": {
        "python": true,
        "rust": true
    }
}
